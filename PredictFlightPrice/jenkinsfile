pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Clone the Git repository
                git 'https://github.com/mamoor2019/ProductionazationOfMLSystem.git'
            }
        }

        stage('Build') {
            steps {
                // Install dependencies and run unit tests
                sh 'pip install -r requirements.txt'
                sh 'pytest'
            }
        }

        stage('Docker Build') {
            steps {
                // Build Docker image
                sh 'docker build -t mamoor/flight-price-pred .'
            }
        }

        stage('Docker Push') {
            steps {
                // Push Docker image to DockerHub
                withCredentials([string(credentialsId: 'dockerhub-credentials', variable: 'DOCKERHUB_PASSWORD')]) {
                    sh 'docker login -u yourusername -p $DOCKERHUB_PASSWORD'
                    sh 'docker push mamoor/flight-price-pred'
                }
            }
        }

        stage('Deploy') {
            steps {
                // Deploy to Kubernetes or any server
                sh 'kubectl apply -f deployment.yml'
            }
        }
    }
    
    post {
        always {
            // Send notifications or cleanup actions
        }
    }
}
